generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  REAL_ESTATE
  ACCOUNT_EXECUTIVE
}

enum DocumentType {
  CPF
  CNPJ
}

enum AutomaticDecisionStatus {
  APPROVED
  REJECTED
  MANUAL_REVIEW
}

enum RecommendationStatus {
  RECOMMENDED
  NOT_RECOMMENDED
  UNKNOWN
}

enum RentalApplicationStatus {
  CONSULTED
  WAITING_CONTRACT_DATA
  WAITING_ADMIN_CONTRACT
  CONTRACT_GENERATED
  REJECTED
  CONTESTED
  ADMIN_REJECTED
  CANCELLED
}

enum AdminDecision {
  APPROVED
  REJECTED
}

enum ContestStatus {
  OPEN
  ACCEPTED
  REJECTED
  CANCELLED
}

enum ContractStatus {
  PENDING
  GENERATED
  FAILED
}

enum ContractSignatureStatus {
  NOT_SENT
  ENVELOPE_CREATED
  SENT
  PARTIALLY_SIGNED
  SIGNED
  ACTION_REQUIRED
  REFUSED
  CANCELLED
  ERROR
}

enum ContractSignerRole {
  TENANT
  REAL_ESTATE
  DOCULOC
}

enum ContractSignerStatus {
  PENDING
  SENT
  SIGNED
  ACTION_REQUIRED
  AUTHENTICATION_FAILED
  REFUSED
  CANCELLED
  ERROR
}

enum CreditLedgerType {
  INITIAL_GRANT
  ADMIN_SET
  ADMIN_INCREMENT
  ADMIN_DECREMENT
  CONSULT_USED
  VIP_ENABLED
  VIP_DISABLED
}

enum OragoConsultStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole

  realEstateProfile RealEstateProfile?

  wallet       UserCreditWallet?
  applications RentalApplication[] @relation("RequesterApplications")

  oragoConsultLocks OragoConsultLock[]

  adminReviewedApplications RentalApplication[] @relation("AdminReviewedApplications")
  generatedContracts        Contract[]          @relation("GeneratedContracts")
  creditLedgerActions       CreditLedger[]      @relation("CreditLedgerActor")

  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  creditLedgers             CreditLedger[]
  rentalApplicationContests RentalApplicationContest[]
  passwordResetTokens       PasswordResetToken[]

  createdContests  RentalApplicationContest[] @relation("CreatedContests")
  reviewedContests RentalApplicationContest[] @relation("ReviewedContests")
}

model PasswordResetToken {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model RealEstateProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String
  cnpj            String? @unique
  phone           String
  responsibleName String

  zipCode      String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserCreditWallet {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  availableCredits Int     @default(3)
  isVip            Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CreditLedger {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  actorId String?
  actor   User?   @relation("CreditLedgerActor", fields: [actorId], references: [id])

  type         CreditLedgerType
  amount       Int
  balanceAfter Int?

  reason String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([actorId])
}

model OragoConsultLock {
  id              String             @id @default(uuid())
  documentType    DocumentType
  document        String             @unique
  requesterId     String
  requester       User               @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  oragoAnalysisId String?            @unique
  status          OragoConsultStatus @default(PROCESSING)
  errorMessage    String?

  rentValue        Decimal?
  condominiumValue Decimal?
  feesValue        Decimal?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requesterId])
  @@index([status])
}

model RentalApplication {
  id String @id @default(uuid())

  documentType DocumentType
  document     String       @unique

  requesterId String
  requester   User   @relation("RequesterApplications", fields: [requesterId], references: [id])

  oragoAnalysisId  String? @unique
  oragoRawResponse String?
  oragoData        String?

  products String?

  rentValue        Decimal
  condominiumValue Decimal
  feesValue        Decimal
  adhesionFee      Decimal?
  requestedExpense Decimal

  automaticDecision AutomaticDecisionStatus
  recommendation    RecommendationStatus

  housingExpenseMin Decimal?
  housingExpenseMax Decimal?

  decisionReasons  String
  decisionMetadata String?

  status RentalApplicationStatus @default(CONSULTED)

  tenantName     String?
  tenantDocument String?
  tenantEmail    String?
  tenantPhone    String?

  propertyZipCode      String?
  propertyStreet       String?
  propertyNumber       String?
  propertyComplement   String?
  propertyNeighborhood String?
  propertyCity         String?
  propertyState        String?

  adminDecision       AdminDecision?
  adminDecisionById   String?
  adminDecisionBy     User?          @relation("AdminReviewedApplications", fields: [adminDecisionById], references: [id])
  adminDecisionAt     DateTime?
  adminDecisionReason String?

  contests RentalApplicationContest[]
  contract Contract?
  tenants  RentalApplicationTenant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requesterId])
  @@index([status])
  @@index([automaticDecision])
}

model RentalApplicationTenant {
  id String @id @default(uuid())

  applicationId String
  application   RentalApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  order Int

  name     String
  document String
  email    String
  phone    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([applicationId, order])
  @@index([applicationId])
}

model RentalApplicationContest {
  id String @id @default(uuid())

  applicationId String
  application   RentalApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("CreatedContests", fields: [createdById], references: [id])

  reason String

  reviewedById String?
  reviewedBy   User?   @relation("ReviewedContests", fields: [reviewedById], references: [id])

  reviewedAt DateTime?
  adminNote  String?

  status ContestStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?

  @@index([applicationId])
  @@index([createdById])
  @@index([status])
}

model Contract {
  id String @id @default(uuid())

  applicationId String            @unique
  application   RentalApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  status ContractStatus @default(PENDING)

  templateName String

  filePath String?
  fileName String?

  mimeType  String?
  sizeBytes Int?

  storageDriver String?
  storageBucket String?
  storageKey    String?

  generatedById String?
  generatedBy   User?   @relation("GeneratedContracts", fields: [generatedById], references: [id])

  errorMessage String?

  generatedAt DateTime?

  clicksignEnvelopeId String?                 @unique
  clicksignDocumentId String?
  signatureStatus     ContractSignatureStatus @default(NOT_SENT)
  signatureError      String?
  sentToSignatureAt   DateTime?
  signedAt            DateTime?

  signers       ContractSigner[]
  webhookEvents ClicksignWebhookEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([signatureStatus])
}

model ContractSigner {
  id String @id @default(uuid())

  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  role ContractSignerRole

  name     String
  email    String
  phone    String?
  document String?

  clicksignSignerId String?
  status            ContractSignerStatus @default(PENDING)

  signedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractId])
  @@index([clicksignSignerId])
  @@index([status])
}

model ClicksignWebhookEvent {
  id String @id @default(uuid())

  contractId String?
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  eventName           String?
  clicksignEnvelopeId String?
  clicksignDocumentId String?
  clicksignSignerId   String?

  payload String

  createdAt DateTime @default(now())

  @@index([contractId])
  @@index([clicksignEnvelopeId])
  @@index([eventName])
}
